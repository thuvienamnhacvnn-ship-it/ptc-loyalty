# ─────────────────────────────────────────────────────────────
# PTC Loyalty Platform — environment variables
# Copy to `.env` and fill in. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon / Supabase / Railway / local)
DATABASE_URL="postgresql://user:password@localhost:5432/ptc_loyalty?schema=public"

# Auth.js — generate with: npx auth secret  (or openssl rand -base64 32)
AUTH_SECRET="replace-me-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — leave blank to disable the Google button)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Public app URL (used for QR links, emails, absolute URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Transactional email (optional — mocked when absent)
RESEND_API_KEY=""
EMAIL_FROM="PTC Loyalty <no-reply@ptc-loyalty.example>"

# Stripe billing (optional — billing UI works in mock mode without these)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# File upload provider key (optional)
UPLOAD_PROVIDER_KEY=""

# Secret used to sign & verify QR member tokens (HMAC). REQUIRED.
# generate with: openssl rand -base64 32
QR_SIGNING_SECRET="replace-me-with-a-long-random-string"

# Secret used to sign & verify desktop POS access tokens (HMAC). Falls back to
# AUTH_SECRET if unset, but a dedicated secret is recommended in production.
# generate with: openssl rand -base64 32
POS_JWT_SECRET="replace-me-with-a-long-random-string"

# ── WhatsApp Business Platform (Meta Cloud API — official) ───────────────────
# NEVER commit real values. Set these in Vercel → Project → Settings → Env Vars.
# All WhatsApp calls are server-side only (Cloud API over HTTPS); no secret is
# ever exposed to the frontend, and no WhatsApp Web automation is used.
#
# 32-byte key used to encrypt per-tenant WhatsApp tokens at rest (AES-256-GCM).
# generate with: openssl rand -base64 32
ENCRYPTION_KEY="replace-me-with-a-32-byte-base64-key"
#
# Meta → App → WhatsApp → API Setup → "Permanent access token" (System User token).
# The sender token used to send messages. REQUIRED. (Server-side only.)
WHATSAPP_ACCESS_TOKEN=""
# Meta → App → WhatsApp → API Setup → your registered number → "Phone number ID".
WHATSAPP_PHONE_NUMBER_ID=""
# Meta → App → Settings → Basic → "App secret". Verifies webhook signatures
# (X-Hub-Signature-256) on incoming events.
WHATSAPP_APP_SECRET=""
# A token YOU choose — must match exactly the "Verify token" you type in the
# Meta webhook config. Current value in use: ptc_loyalty_2026
WHATSAPP_WEBHOOK_VERIFY_TOKEN="ptc_loyalty_2026"
#
# Approved image-header template for the membership card (business-initiated to
# any customer, outside the 24h window). Leave blank to send free-form image
# (works only for test numbers / inside the 24h window).
#   WHATSAPP_MEMBER_TEMPLATE      = the approved template name (e.g. ptc_welcome)
#   WHATSAPP_MEMBER_TEMPLATE_LANG = its language code (e.g. vi)  — must match Meta
# Template must have: Header = Image, Body variables {{1}} = tên khách, {{2}} = mã TV.
WHATSAPP_MEMBER_TEMPLATE=""
WHATSAPP_MEMBER_TEMPLATE_LANG="vi"
#
# Note: businesses can ALSO connect WhatsApp per-tenant in the dashboard
# (Settings → WhatsApp) — that path stores the token encrypted (ENCRYPTION_KEY).
# The env vars above are the single-business / default sender.

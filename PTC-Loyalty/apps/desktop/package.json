{
  "name": "ptc-loyalty-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "PTC Loyalty — Windows counter/kiosk client for Business Owner, Manager and Staff.",
  "author": "PTC Loyalty",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "node scripts/build-electron.mjs && wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:renderer": "vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "build": "npm run typecheck && npm run build:renderer && npm run build:electron",
    "dist": "npm run build && electron-builder --win --publish never",
    "dist:unsigned": "npm run build && electron-builder --win -c.win.signAndEditExecutable=false --publish never",
    "dist:msi": "npm run build && electron-builder --win msi -c.win.signAndEditExecutable=false --publish never",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "start": "electron ."
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.469.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "wait-on": "^8.0.2"
  }
}
